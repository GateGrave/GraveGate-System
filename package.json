{
  "name": "gategrave-bot-system",
  "version": "0.1.0",
  "description": "Phase 1 scaffolding for an event-driven Discord RPG backend.",
  "private": true,
  "main": "src/index.js",
  "type": "commonjs",
  "scripts": {
    "start": "node src/index.js",
    "gateway:start": "node apps/gateway/src/index.js",
    "discord:register": "node apps/gateway/src/discord/registerCommandsRunner.js",
    "phase1:flow": "node src/phase1-mock-flow.js",
    "test": "node -e \"console.log('Test placeholder: no automated tests added yet for Phase 1.')\"",
    "test:loot-core": "node apps/world-system/src/loot/testing/loot-core-schema.test.js",
    "test:loot-table": "node apps/world-system/src/loot/testing/loot-table-system.test.js",
    "test:loot-roll": "node apps/world-system/src/loot/testing/loot-roll-resolver.test.js",
