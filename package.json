    "test:loot-boss-hook": "node apps/world-system/src/loot/testing/boss-guaranteed-drop-hook.test.js",
    "test:loot-assignment": "node apps/world-system/src/loot/testing/individual-loot-assignment.test.js",
    "test:loot-grant": "node apps/world-system/src/loot/testing/loot-grant-integration.test.js",
    "test:loot-logging": "node apps/world-system/src/loot/testing/loot-logging-system.test.js",
    "test:loot-harness": "node apps/world-system/src/loot/testing/loot-testing-harness.test.js",
    "test:currency-core": "node apps/world-system/src/currency/testing/currency-core.test.js",
    "test:economy-transactions": "node apps/world-system/src/economy/testing/economy-transaction-schema.test.js",
    "test:npc-shop-core": "node apps/world-system/src/economy/testing/npc-shop-core.test.js",
    "test:npc-shop-purchase": "node apps/world-system/src/economy/testing/npc-shop-purchase-flow.test.js",
    "test:npc-shop-sell": "node apps/world-system/src/economy/testing/npc-shop-sell-flow.test.js",
    "test:player-shop-core": "node apps/world-system/src/economy/testing/player-shop-core.test.js",
    "test:player-listing-flow": "node apps/world-system/src/economy/testing/player-listing-flow.test.js",
    "test:player-shop-purchase": "node apps/world-system/src/economy/testing/player-shop-purchase-flow.test.js",
    "test:economy-logging": "node apps/world-system/src/economy/testing/economy-transaction-logging.test.js",
    "test:economy-snapshot": "node apps/world-system/src/economy/testing/economy-snapshot-recovery.test.js",
    "test:economy-harness": "node apps/world-system/src/economy/testing/economy-harness.test.js",
    "simulate:economy": "node apps/world-system/src/economy/testing/economy-simulation-runner.js",
    "simulate:loot": "node apps/world-system/src/loot/testing/loot-simulation-runner.js",
    "test:recipe-core": "node apps/world-system/src/crafting/testing/recipe-core.test.js",
    "test:recipe-requirements": "node apps/world-system/src/crafting/testing/resource-requirement-system.test.js",
    "test:crafting-eligibility": "node apps/world-system/src/crafting/testing/crafting-eligibility-validator.test.js",
    "test:crafting-jobs": "node apps/world-system/src/crafting/testing/crafting-job-progress.test.js",
    "test:crafting-checks": "node apps/world-system/src/crafting/testing/crafting-check-resolver.test.js",
    "test:crafting-completion": "node apps/world-system/src/crafting/testing/craft-completion-output-resolver.test.js",
    "test:crafting-finalize": "node apps/world-system/src/crafting/testing/craft-resource-consumption-rollback.test.js",
    "test:crafting-logging": "node apps/world-system/src/crafting/testing/crafting-logging-system.test.js",
    "test:crafting-snapshot": "node apps/world-system/src/crafting/testing/crafting-snapshot-recovery.test.js",
    "test:crafting-harness": "node apps/world-system/src/crafting/testing/crafting-harness.test.js",
    "simulate:crafting": "node apps/world-system/src/crafting/testing/crafting-simulation-runner.js",
    "test:guild-core": "node apps/world-system/src/guild/testing/guild-core.test.js",
    "test:guild-membership": "node apps/world-system/src/guild/testing/guild-membership-flow.test.js",
    "test:guild-storage": "node apps/world-system/src/guild/testing/guild-shared-storage.test.js",
    "test:guild-progression": "node apps/world-system/src/guild/testing/guild-progression-system.test.js",
    "test:raid-core": "node apps/world-system/src/raid/testing/raid-core.test.js",
    "test:raid-coordination": "node apps/world-system/src/raid/testing/raid-coordination-system.test.js",
    "test:world-events-core": "node apps/world-system/src/world-events/testing/world-event-core.test.js",
    "test:world-boss-system": "node apps/world-system/src/world-events/testing/world-boss-system.test.js",
    "test:seasonal-events": "node apps/world-system/src/world-events/testing/seasonal-event-system.test.js",
    "test:hunter-association-core": "node apps/world-system/src/hunter-association/testing/hunter-association-core.test.js",
    "test:contract-hunt-board": "node apps/world-system/src/hunter-association/testing/contract-hunt-board-system.test.js",
    "test:ranking-system": "node apps/world-system/src/ranking/testing/ranking-system.test.js",
    "test:advanced-systems-snapshot": "node apps/world-system/src/advanced-systems/testing/advanced-systems-snapshot-recovery.test.js",
    "test:advanced-systems-harness": "node apps/world-system/src/advanced-systems/testing/advanced-systems-harness.test.js",
    "simulate:advanced-systems": "node apps/world-system/src/advanced-systems/testing/advanced-systems-simulation-runner.js",
    "test:gateway": "node scripts/run-node-tests.js --include=apps/gateway",
    "test:persistence": "node apps/database/src/testing/databaseAdapter.test.js && node apps/database/src/testing/sqliteAdapter.test.js && node apps/world-system/src/account/testing/accountPersistenceAdapter.test.js && node apps/world-system/src/account/testing/accountOwnershipFoundation.test.js && node apps/world-system/src/account/testing/accountSlotActiveCharacter.test.js && node apps/world-system/src/character/testing/characterPersistenceAdapter.test.js && node apps/inventory-system/src/testing/inventoryPersistenceAdapter.test.js && node apps/dungeon-exploration/src/testing/sessionPersistenceAdapter.test.js && node apps/combat-system/src/testing/combatPersistenceAdapter.test.js",
    "test:runtime": "node scripts/run-node-tests.js --include=apps/runtime,apps/controller",
    "test:subsystems": "node scripts/run-node-tests.js --include=apps/world-system,apps/dungeon-exploration,apps/combat-system,apps/inventory-system",
    "test:harness": "node scripts/run-node-tests.js --include=apps --contains=harness",
    "test:hardening": "node apps/world-system/src/economy/testing/npcShopSellValidation.test.js && node apps/world-system/src/economy/testing/npcShopSellOwnership.test.js && node apps/world-system/src/character/testing/characterInventoryLinkValidation.test.js && node apps/inventory-system/src/testing/inventoryMutationHelpers.test.js",
    "test:foundation": "npm run test:persistence && npm run test:subsystems",
    "test:stage13": "npm run test:gateway && npm run test:foundation && npm run test:harness",
    "test:stage14": "npm run test:gateway && npm run test:runtime && npm run test:persistence && node apps/dungeon-exploration/src/testing/firstPlayableLoopHarness.test.js && npm run test:hardening",
    "test:all": "npm run test:stage13 && npm run test:stage14",
    "alpha:preflight": "node scripts/alpha-preflight.js",
    "alpha:preflight:strict": "node scripts/alpha-preflight.js --require-discord-env",
    "alpha:gate": "npm run alpha:preflight:strict && npm run test:alpha:smoke && npm run test:alpha:regression",
    "alpha:smoke:internal": "node scripts/internal-alpha-smoke.js",
    "alpha:smoke:internal:strict": "node scripts/internal-alpha-smoke.js --strict-preflight",
    "test:alpha:tooling": "node scripts/testing/alphaPreflight.test.js && node scripts/testing/internalAlphaSmoke.test.js",
    "test:alpha:smoke": "node apps/world-system/src/content/testing/contentLoader.test.js && node apps/world-system/src/character/testing/characterRulesHooks.test.js && node apps/runtime/src/testing/readCommandRuntime.test.js && node apps/dungeon-exploration/src/testing/dungeonLoopStabilization.test.js && node apps/combat-system/src/testing/processCombatActionRequest.test.js && node apps/combat-system/src/testing/combatRenderIntegration.test.js && node apps/runtime/src/testing/multiplayerFoundationRuntime.test.js",
    "test:alpha:regression": "npm run test:stage14 && npm run test:harness && npm run test:alpha:tooling",
    "test:alpha": "npm run alpha:preflight && npm run test:alpha:smoke && npm run test:alpha:regression"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "discord.js": "^14.25.1",
    "dotenv": "^17.3.1"
  }
}


